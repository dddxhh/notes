{
  "name": "@notes/web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "NODE_OPTIONS='--max-old-space-size=4096' vitest run",
